<script>
  const answers = { q1: null, q2: null, q3: null };

  function go(screenId) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById(screenId).classList.add('active');
    window.scrollTo(0, 0);
  }

  function select(el, question, value, next) {
    // Deselect siblings
    el.closest('.options').querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    answers[question] = value;
    if (next) {
      setTimeout(() => go(next), 220);
    }
  }

  function route() {
    // Called after Q3 manufacturer/importer selection
    // Need a small delay to let the selection register visually
    setTimeout(() => {
      const q2 = answers.q2;
      const q3 = answers.q3;
      if (q2 === 'textiles' && q3 === 'manufacturer') go('screen-out-01');
      else if (q2 === 'textiles' && q3 === 'importer') go('screen-out-02');
      else if (q2 === 'mixed' && q3 === 'manufacturer') go('screen-out-03');
      else if (q2 === 'mixed' && q3 === 'importer') go('screen-out-04');
    }, 220);
  }

  function restart() {
    answers.q1 = null; answers.q2 = null; answers.q3 = null;
    document.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
    go('screen-start');
  }
</script>
